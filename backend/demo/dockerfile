# Use a lightweight JDK image to build the Spring Boot application
FROM eclipse-temurin:21-jdk-alpine AS build

WORKDIR /app

# Copy Maven wrapper and project metadata first to leverage Docker layer caching
COPY .mvn .mvn
COPY mvnw pom.xml ./
RUN chmod +x mvnw

# Download dependencies (kept in a separate layer to speed up future builds)
RUN ./mvnw dependency:go-offline

# Copy the actual source code and build the runnable jar
COPY src ./src
RUN ./mvnw package -DskipTests

# Runtime image containing only the compiled application
FROM eclipse-temurin:21-jre-alpine

WORKDIR /app
COPY --from=build /app/target/*.jar app.jar

EXPOSE 8080

ENTRYPOINT ["java", "-jar", "app.jar"]
